firmament:
  version: 1

model:
  name: m7d_valid_boolean_chain_placement
  units: mm

ops[4]:
  -
    op: box
    id: base
    size[3]:
      6
      6
      6

  -
    op: add
    id: join1
    to: base
    with:
      op: box
      size[3]:
        1
        1
        1

  -
    op: add
    id: join2
    to: join1
    with:
      op: box
      size[3]:
        1
        1
        1
    place:
      on: origin
      offset[3]:
        -4
        2
        0

  -
    op: expect_exists
    target: join2
