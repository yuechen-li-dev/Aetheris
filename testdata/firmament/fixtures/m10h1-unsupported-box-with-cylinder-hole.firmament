firmament:
  version: 1

model:
  name: m10h1_unsupported_box_with_partial_cylinder_hole
  units: mm

schema:
  process: additive
  printer_resolution: 0.1

ops[2]:
  -
    op: box
    id: base
    size[3]:
      40
      30
      12

  -
    op: subtract
    id: hole
    from: base
    with:
      op: cylinder
      radius: 4
      height: 8
