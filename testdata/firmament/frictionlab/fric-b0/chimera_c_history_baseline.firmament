firmament:
  version: 1
model:
  name: fric_b0_chimera_c_history_baseline
  units: mm
ops[3]:
  -
    op: box
    id: chimera_c_root
    size[3]: [60, 40, 20]
  -
    op: subtract
    id: zone_ca_analytic_seed_hole
    from: chimera_c_root
    with:
      op: cylinder
      radius: 4
      height: 30
  -
    op: subtract
    id: zone_cb_second_analytic_hole
    from: zone_ca_analytic_seed_hole
    with:
      op: cone
      bottom_radius: 3.5
      top_radius: 2
      height: 30
    place:
      on: origin
      offset[3]: [14, 0, 0]
