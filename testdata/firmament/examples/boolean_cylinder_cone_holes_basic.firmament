firmament:
  version: 1

model:
  name: boolean_cylinder_cone_holes_basic
  units: mm

ops[3]:
  -
    op: box
    id: base
    size[3]:
      40
      30
      12

  -
    op: subtract
    id: hole_a
    from: base
    with:
      op: cylinder
      radius: 4
      height: 20
    place:
      on: origin
      offset[3]:
        -15
        0
        0

  -
    op: subtract
    id: cut_b
    from: hole_a
    with:
      op: cone
      bottom_radius: 3
      top_radius: 5
      height: 20
