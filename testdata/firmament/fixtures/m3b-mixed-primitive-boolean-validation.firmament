firmament:
  version: 1

model:
  name: demo
  units: mm

ops[5]:
  -
    op: box
    id: base
    size[3]:
      4
      5
      6

  -
    op: add
    id: join1
    to: base
    with:
      op: sphere

  -
    op: cylinder
    id: cap
    radius: 2
    height: 9

  -
    op: subtract
    id: cut1
    from: join1
    with:
      op: box

  -
    op: expect_exists
    target: cut1
