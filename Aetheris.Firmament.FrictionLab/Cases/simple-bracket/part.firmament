firmament:
  version: 1

model:
  name: friction_simple_bracket
  units: mm

ops[2]:
  -
    op: box
    id: base
    size[3]:
      60
      20
      8

  -
    op: add
    id: bracket
    to: base
    with:
      op: box
      id: upright
      size[3]:
        20
        20
        40
    place:
      on: origin
      offset[3]:
        -20
        0
        16
