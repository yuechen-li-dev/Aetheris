firmament:
  version: 1

model:
  name: m8c-invalid-cnc-tool-radius
  units: mm

schema:
  process: cnc
  minimum_tool_radius: 1
  minimum_wall_thickness: 0.5

ops[2]:
  -
    op: box
    id: base
    size[3]:
      4
      2
      2
  -
    op: add
    id: lshape
    to: base
    with:
      op: box
      size[3]:
        2
        4
        2
    place:
      on: origin
      offset[3]:
        -1
        1
        0
