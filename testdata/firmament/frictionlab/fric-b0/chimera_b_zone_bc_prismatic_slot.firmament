firmament:
  version: 1
model:
  name: fric_b0_chimera_b_zone_bc_prismatic_slot
  units: mm
ops[2]:
  -
    op: cylinder
    id: chimera_b_root
    radius: 25
    height: 20
  -
    op: subtract
    id: zone_bc_prismatic_slot
    from: chimera_b_root
    with:
      op: straight_slot
      length: 20
      width: 8
      height: 24
