firmament:
  version: 1

model:
  name: demo
  units: mm

ops[6]:
  -
    op: box
    id: base
    size[3]:
      10
      10
      10

  -
    op: add
    id: join1
    to: base
    with:
      op: box
      size[3]:
        1
        1
        1
    place:
      on: origin
      offset[3]:
        10
        0
        0

  -
    op: sphere
    id: cap
    radius: 3

  -
    op: subtract
    id: cut1
    from: join1
    with:
      op: box
      size[3]:
        1
        1
        1

  -
    op: subtract
    id: clip1
    from: cut1
    with:
      op: box
      size[3]:
        1
        1
        1

  -
    op: expect_exists
    target: clip1
