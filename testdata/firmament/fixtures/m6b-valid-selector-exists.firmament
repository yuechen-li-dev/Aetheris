firmament:
  version: 1

model:
  name: m6b_valid_selector_exists
  units: mm

ops[8]:
  -
    op: box
    id: base
    size[3]:
      10
      8
      6
  -
    op: sphere
    id: sphere
    radius: 4
  -
    op: cylinder
    id: cyl
    radius: 2
    height: 5
  -
    op: add
    id: join
    to: base
    with:
      op: box
      size[3]:
        1
        1
        1
  -
    op: expect_exists
    target: base.top_face
  -
    op: expect_exists
    target: sphere.surface
  -
    op: expect_exists
    target: cyl.side_face
  -
    op: expect_exists
    target: join.edges
