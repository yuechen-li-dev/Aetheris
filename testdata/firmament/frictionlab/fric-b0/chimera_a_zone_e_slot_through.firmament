firmament:
  version: 1
model:
  name: fric_b0_chimera_a_zone_e_slot_through
  units: mm
ops[2]:
  -
    op: box
    id: chimera_a_root
    size[3]: [60, 40, 20]
  -
    op: subtract
    id: zone_e_slot_through
    from: chimera_a_root
    with:
      op: slot_cut
      length: 18
      width: 8
      height: 24
      corner_radius: 4
