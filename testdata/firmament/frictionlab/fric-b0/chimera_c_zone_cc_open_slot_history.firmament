firmament:
  version: 1
model:
  name: fric_b0_chimera_c_zone_cc_open_slot_history
  units: mm
ops[3]:
  -
    op: box
    id: chimera_c_root
    size[3]: [60, 40, 20]
  -
    op: subtract
    id: zone_cc_open_slot_seed
    from: chimera_c_root
    with:
      op: straight_slot
      length: 20
      width: 8
      height: 24
  -
    op: subtract
    id: zone_cc_follow_on_prism
    from: zone_cc_open_slot_seed
    with:
      op: box
      size[3]: [10, 10, 24]
