firmament:
  version: 1

model:
  name: demo
  units: mm

ops[6]:
  -
    op: box
    id: base
    size[3]:
      10
      10
      10

  -
    op: add
    id: join1
    to: base
    with:
      op: cylinder
      radius: 1
      height: 1

  -
    op: sphere
    id: cap
    radius: 3

  -
    op: subtract
    id: cut1
    from: join1
    with:
      op: sphere
      radius: 1

  -
    op: intersect
    id: clip1
    left: cut1
    with:
      op: box
      size[3]:
        1
        1
        1

  -
    op: expect_exists
    target: clip1
