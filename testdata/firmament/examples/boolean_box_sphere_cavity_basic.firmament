firmament:
  version: 1

model:
  name: boolean_box_sphere_cavity_basic
  units: mm

schema:
  process: additive
  printer_resolution: 0.1

ops[2]:
  -
    op: box
    id: base
    size[3]:
      40
      30
      12

  -
    op: subtract
    id: cavity
    from: base
    with:
      op: sphere
      radius: 4
