firmament:
  version: 1

model:
  name: m7e_invalid_pmi_dimension_missing_datum
  units: mm

ops[2]:
  -
    op: box
    id: base
    size[3]:
      40
      40
      20

  -
    op: subtract
    id: hole
    from: base
    with:
      op: cylinder
      radius: 4
      height: 30

pmi[1]:
  -
    kind: dimension
    dimension_kind: linear_distance_to_datum
    target: hole
    datum: Z
    value: 8
