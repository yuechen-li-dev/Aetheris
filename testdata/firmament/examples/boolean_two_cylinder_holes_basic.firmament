firmament:
  version: 1

model:
  name: boolean_two_cylinder_holes_basic
  units: mm

ops[3]:
  -
    op: box
    id: base
    size[3]:
      40
      30
      12

  -
    op: subtract
    id: hole_a
    from: base
    with:
      op: cylinder
      radius: 4
      height: 20
    place:
      on: origin
      offset[3]:
        -15
        0
        0

  -
    op: subtract
    id: hole_b
    from: hole_a
    with:
      op: cylinder
      radius: 3
      height: 20
