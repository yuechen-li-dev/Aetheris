firmament:
  version: 1

model:
  name: friction_simple_bracket
  units: mm

ops[2]:
  -
    op: box
    id: base
    size[3]:
      60
      20
      10
    place:
      on: origin
      offset[3]:
        30
        10
        0

  -
    op: add
    id: bracket
    to: base
    with:
      op: box
      id: upright
      size[3]:
        10
        20
        60
    place:
      on: origin
      offset[3]:
        5
        10
        0
