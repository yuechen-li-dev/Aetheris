firmament:
  version: 1

model:
  name: m7b_valid_placement_selector_anchor_boolean
  units: mm

ops[3]:
  -
    op: box
    id: base
    size[3]:
      4
      4
      4

  -
    op: add
    id: union
    to: base
    with:
      op: cylinder
      radius: 1
      height: 2

  -
    op: box
    id: placed
    size[3]:
      1
      1
      1
    place:
      on: union.edges
      offset[3]:
        0
        0
        0
