firmament:
  version: 1

model:
  name: cnc_min_tool_radius_demo
  units: mm

schema:
  process: cnc
  minimum_tool_radius: 2

ops[2]:
  -
    op: box
    id: base
    size[3]:
      24
      24
      12

  -
    op: subtract
    id: hole
    from: base
    with:
      op: cylinder
      radius: 2
      height: 12
